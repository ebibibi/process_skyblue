# Process SkyBlue Configuration
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env

# Bluesky Settings
# App Password の使用を推奨: https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=your-account.bsky.social
BLUESKY_PASSWORD=your-app-password

# X (Twitter) API Settings
# https://developer.twitter.com/en/portal/dashboard でAPIキーを取得
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# X API OAuth 2.0（将来の機能拡張用・現在は未使用）
# X_OAUTH2_CLIENT_ID=your-oauth2-client-id
# X_OAUTH2_CLIENT_SECRET=your-oauth2-client-secret

# Discord Webhook for Error Notifications（必須）
# エラー通知・投稿成功通知の送信先
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Discord Webhook for cross-posting（任意）
# 設定するとBlueSkyの投稿をDiscordにもクロスポスト
# DISCORD_EBILOG_WEBHOOK_URL=https://discord.com/api/webhooks/your-ebilog-webhook-url

# Application Settings
# ポーリング間隔（秒）。最小10・最大3600
POLLING_INTERVAL=60

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# X Premium Mode
# true: 25,000文字まで単一ポスト + スレッドマージ機能
# false: 280文字制限・超過時はスレッド分割（X Free プラン）
X_PREMIUM=true
